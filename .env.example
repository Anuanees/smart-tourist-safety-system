# ─────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your values.
# This file is safe to commit — .env is NOT.
# ─────────────────────────────────────────────────────────

# Generate a strong key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-long-random-secret-key-here

# False on production, True only for local dev
DEBUG=False

# Your deployed domain, e.g.: myapp.railway.app,myapp.onrender.com
ALLOWED_HOSTS=yourdomain.railway.app,yourdomain.onrender.com

# PostgreSQL connection URL (provided by Railway / Render / Supabase / etc.)
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://user:password@host:5432/dbname
